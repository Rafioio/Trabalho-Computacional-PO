// =================================================================
// MODELO DE LOCALIZAÇÃO DE PARADAS DE ÔNIBUS
// =================================================================

// =================================================================
// 1. Conjuntos e Índices
// =================================================================

int NumN = ...;
range N = 1..NumN;

{int} C = ...;
assert forall(i in C) i in N;

{int} T = {i | i in N : !(i in C)};

int NumK = ...;
range K = 1..NumK;

int NumQ = ...;
range Q = 1..NumQ;

// -----------------------------------------------------
// Pares válidos rota-parada
// -----------------------------------------------------

tuple ParRotaParada {
   int n;
   int k;
}

setof(ParRotaParada) I = ...;

// -----------------------------------------------------
// Pares válidos demanda-rota
// -----------------------------------------------------

tuple DemandaRota {
   int q;
   int k;
}

setof(DemandaRota) L = ...;

// =================================================================
// 2. Parâmetros
// =================================================================

// -----------------------------------------------------
// Distância caminhada demanda-parada
// -----------------------------------------------------

float d[Q][N] = ...;

// -----------------------------------------------------
// Nível de demanda
// -----------------------------------------------------

float de[Q] = ...;

// -----------------------------------------------------
// Distâncias máximas
// -----------------------------------------------------

float d_route_max = ...;
float d_walk_max  = ...;

// -----------------------------------------------------
// Penalidade por não atendimento
// -----------------------------------------------------

float P = ...;

// -----------------------------------------------------
// Viabilidade técnica do ponto
// -----------------------------------------------------

float w[N] = ...;

// -----------------------------------------------------
// Capacidade total disponível
// -----------------------------------------------------

int Capt = ...;

// -----------------------------------------------------
// Número máximo de rotas por ponto
// -----------------------------------------------------

int m_max = ...;

// -----------------------------------------------------
// Distância viária da rota
// -----------------------------------------------------

float D[K][N][N] = ...;

// -----------------------------------------------------
// Rotas ordenadas
// -----------------------------------------------------

int V_tamanho[K] = ...;

int V[K][1..NumN] = ...;

// -----------------------------------------------------
// Pesos da função objetivo
// -----------------------------------------------------

float W1 = ...;
float W2 = ...;
float W3 = ...;
float W4 = ...;

// =================================================================
// 3. Domínios Dispersos
// =================================================================

// -----------------------------------------------------
// Domínio da variável a[q,n,k]
// -----------------------------------------------------

tuple DemandaParadaRota {
   int q;
   int n;
   int k;
}

setof(DemandaParadaRota) a_domain =
{
    <q,n,k> |
    q in Q,
    <n,k> in I,
    <q,k> in L :
    d[q][n] <= d_walk_max
};

// -----------------------------------------------------
// Índices da variável de folga s_k
// -----------------------------------------------------

tuple s_info {
    int k;
    int idx;
}

setof(s_info) S_Indices =
{
    <k, idx> |
    k in K,
    idx in 2..V_tamanho[k]
};

// =================================================================
// 4. Variáveis de Decisão
// =================================================================

// -----------------------------------------------------
// Ativação do ponto
// -----------------------------------------------------

dvar boolean x[N];

// -----------------------------------------------------
// Rota opera no ponto
// -----------------------------------------------------

dvar boolean x_k[I];

// -----------------------------------------------------
// Fração da demanda atribuída
// -----------------------------------------------------

dvar float+ a[a_domain] in 0..1;

// -----------------------------------------------------
// Capacidade da rota
// -----------------------------------------------------

dvar int+ Cap[K];

// -----------------------------------------------------
// Variável de folga de espaçamento
// -----------------------------------------------------

dvar float+ s_k[S_Indices];

// =================================================================
// 5. Funções Objetivo
// =================================================================

// -----------------------------------------------------
// f1 = custo social
// -----------------------------------------------------

dexpr float f1 =

    sum(q in Q)

        de[q] *

        (

            sum(<q,n,k> in a_domain)

                d[q][n] * a[<q,n,k>]

            +

            (

                1

                -

                sum(<q,n,k> in a_domain)

                    a[<q,n,k>]

            )

            * P

        );

// -----------------------------------------------------
// f2 = viabilidade técnica
// -----------------------------------------------------

dexpr float f2 =

    sum(<n,k> in I)

        (1 / w[n]) * x_k[<n,k>];

// -----------------------------------------------------
// f3 = custo de infraestrutura
// -----------------------------------------------------

dexpr float f3 =

    sum(n in T)

        x[n];

// -----------------------------------------------------
// f4 = penalidade de espaçamento
// -----------------------------------------------------

dexpr float f4 =

    sum(si in S_Indices)

        s_k[si];

// -----------------------------------------------------
// Função Objetivo Agregada
// -----------------------------------------------------

minimize

    W1 * f1 +

    W2 * f2 +

    W3 * f3 +

    W4 * f4;

// =================================================================
// 6. Restrições
// =================================================================

subject to {

    // -------------------------------------------------
    // (1) Ativação da infraestrutura
    // -------------------------------------------------

    forall(<n,k> in I)

        x_k[<n,k>] <= x[n];

    // -------------------------------------------------
    // (2) Viabilidade de embarque
    // -------------------------------------------------

    forall(<q,n,k> in a_domain)

        a[<q,n,k>] <= x_k[<n,k>];

    // -------------------------------------------------
    // (3) Conservação da demanda
    // -------------------------------------------------

    forall(q in Q)

        sum(<q,n,k> in a_domain)

            a[<q,n,k>]

        <= 1;

    // -------------------------------------------------
    // (4) Terminais obrigatórios
    // -------------------------------------------------

    forall(k in K) {

        x_k[<V[k][1], k>] == 1;

        x_k[<V[k][V_tamanho[k]], k>] == 1;
    }

    // -------------------------------------------------
    // (5) Espaçamento máximo com folga
    // -------------------------------------------------

    forall(si in S_Indices) {

        x_k[<V[si.k][si.idx], si.k>]

        <=

        sum(

            idx_gamma in 1..(si.idx-1) :

            D[si.k]
             [V[si.k][idx_gamma]]
             [V[si.k][si.idx]]

            <= d_route_max

        )

        x_k[<V[si.k][idx_gamma], si.k>]

        +

        s_k[si];
    }

    // -------------------------------------------------
    // (6) Capacidade da rota
    // -------------------------------------------------

    forall(k in K)

        sum(<q,n,k> in a_domain)

            a[<q,n,k>] * de[q]

        <= Cap[k];

    // -------------------------------------------------
    // (7) Limite operacional do ponto
    // -------------------------------------------------

    forall(n in N)

        sum(<n,k> in I)

            x_k[<n,k>]

        <= m_max * x[n];

    // -------------------------------------------------
    // (8) Capacidade total do sistema
    // -------------------------------------------------

    sum(k in K)

        Cap[k]

    <= Capt;
}

